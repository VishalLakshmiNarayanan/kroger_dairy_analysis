    <worksheet name='spoilage'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Tableau Semibold'>INVENTORY SPOILAGE &amp; SHELF SPACE AUDIT</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='dim_date+' name='federated.1yusy0k06amojl1gqbz650jbti1k' />
          </datasources>
          <datasource-dependencies datasource='federated.1yusy0k06amojl1gqbz650jbti1k'>
            <column caption='spoilage risk status' datatype='string' name='[Calculation_0798293122813952]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [inventory_risk_code] = 0 AND [base_price] = [sale_price] &#13;&#10;THEN &quot;CRITICAL: High Stock / No Discount&quot;&#13;&#10;ELSEIF [inventory_risk_code] = 0 AND [base_price] &gt; [sale_price]&#13;&#10;THEN &quot;Monitor: High Stock / On Sale&quot;&#13;&#10;ELSE &quot;Stable&quot;&#13;&#10;END' />
            </column>
            <column caption='Base Price' datatype='real' name='[base_price]' role='measure' type='quantitative' />
            <column caption='Inventory Risk Code' datatype='integer' name='[inventory_risk_code]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_0798293122813952]' derivation='None' name='[none:Calculation_0798293122813952:nk]' pivot='key' type='nominal' />
            <column-instance column='[product_description]' derivation='None' name='[none:product_description:nk]' pivot='key' type='nominal' />
            <column caption='Product Description' datatype='string' name='[product_description]' role='dimension' type='nominal' />
            <column caption='Sale Price' datatype='real' name='[sale_price]' role='measure' type='quantitative' />
            <column-instance column='[sale_price]' derivation='Sum' name='[sum:sale_price:qk]' pivot='key' type='quantitative' />
            <column-instance column='[total_shelf_facings]' derivation='Sum' name='[sum:total_shelf_facings:qk]' pivot='key' type='quantitative' />
            <column caption='Total Shelf Facings' datatype='integer' name='[total_shelf_facings]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.1yusy0k06amojl1gqbz650jbti1k].[none:Calculation_0798293122813952:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;CRITICAL: High Stock / No Discount&quot;</bucket>
              <bucket>&quot;Monitor: High Stock / On Sale&quot;</bucket>
              <bucket>&quot;Stable&quot;</bucket>
            </dictionary>
          </manual-sort>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='size-bar' field='[federated.1yusy0k06amojl1gqbz650jbti1k].[sum:total_shelf_facings:qk]' field-type='quantitative' max-size='1' min-size='0.005' type='centersize' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#f5ead7' />
