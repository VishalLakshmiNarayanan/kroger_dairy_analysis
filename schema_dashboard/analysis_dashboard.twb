      <column caption='spoilage risk status' datatype='string' name='[Calculation_0798293122813952]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [inventory_risk_code] = 0 AND [base_price] = [sale_price] &#13;&#10;THEN &quot;CRITICAL: High Stock / No Discount&quot;&#13;&#10;ELSEIF [inventory_risk_code] = 0 AND [base_price] &gt; [sale_price]&#13;&#10;THEN &quot;Monitor: High Stock / On Sale&quot;&#13;&#10;ELSE &quot;Stable&quot;&#13;&#10;END' />
      </column>
